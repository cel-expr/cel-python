load("//third_party/pybind11/google3_utils:build_defs.bzl", "pybind_extension")

# This project is WIP - do not add visibility for now
package(
    default_applicable_licenses = ["//devtools/compliance/licenses:no_external_contributions"],
    default_visibility = ["//visibility:private"],
)

pybind_extension(
    name = "ext_math",
    srcs = [
        "ext_math.cc",
    ],
    visibility = ["//third_party/cel/python:friends"],
    deps = [
        "//google/api/expr:checked_cc_proto",
        "//third_party/absl/base:nullability",
        "//third_party/absl/status",
        "//third_party/absl/status:statusor",
        "//third_party/absl/types:span",
        "//third_party/cel/cpp/checker:type_checker_builder",
        "//third_party/cel/cpp/common:decl",
        "//third_party/cel/cpp/common:function_descriptor",
        "//third_party/cel/cpp/common:kind",
        "//third_party/cel/cpp/common:type",
        "//third_party/cel/cpp/common:value",
        "//third_party/cel/cpp/compiler",
        "//third_party/cel/cpp/extensions:math_ext",
        "//third_party/cel/cpp/extensions:math_ext_decls",
        "//third_party/cel/cpp/runtime:function",
        "//third_party/cel/cpp/runtime:runtime_builder",
        "//third_party/cel/cpp/runtime:runtime_options",
        "//third_party/cel/python:cel_extension",
        "//third_party/protobuf",
        "//third_party/protobuf:arena",
        "//util/task:status",
    ],
)
